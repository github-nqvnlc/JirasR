{% doc %}
  Renders an inline SVG icon.

  @param {string} name - Icon name
  @param {string} [class] - Additional class names
  @param {number} [size] - Icon size in pixels
{% enddoc %}

{% liquid
  assign icon_name = name | default: 'check'
  assign icon_size = size | default: 18
%}

<span
  class="tiktok-icon {{ class }}"
  style="--icon-size: {{ icon_size }}px;"
  aria-hidden="true"
>
  {% case icon_name %}
    {% when 'check' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13.2 9.2 17 19 7"/></svg>
    {% when 'cross' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M6 6l12 12M18 6 6 18"/></svg>
    {% when 'spark' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 3 1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5L12 3ZM19 16l.7 2.3L22 19l-2.3.7L19 22l-.7-2.3L16 19l2.3-.7L19 16ZM5 16l.7 2.3L8 19l-2.3.7L5 22l-.7-2.3L2 19l2.3-.7L5 16Z"/></svg>
    {% when 'star' %}
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="m12 2.8 2.9 5.9 6.5.9-4.7 4.6 1.1 6.5L12 17.6 6.2 20.7l1.1-6.5L2.6 9.6l6.5-.9L12 2.8Z"/></svg>
    {% when 'play' %}
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.5v13l10-6.5L8 5.5Z"/></svg>
    {% when 'shield' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3 5 6v5c0 4.8 2.8 8.9 7 10 4.2-1.1 7-5.2 7-10V6l-7-3Z"/><path d="m9 12 2 2 4-4"/></svg>
    {% when 'ship' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h11v8H3z"/><path d="M14 10h3l4 4v1h-7z"/><circle cx="7" cy="18" r="2"/><circle cx="18" cy="18" r="2"/></svg>
    {% when 'view' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
    {% when 'verified' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 12 2 2 4-4"/><path d="m12 3 2.6 1.7 3.1-.1 1 2.9 2.5 1.8-1.1 2.8 1.1 2.8-2.5 1.8-1 2.9-3.1-.1L12 21l-2.6-1.7-3.1.1-1-2.9L2.8 14.7l1.1-2.8-1.1-2.8L5.3 7.3l1-2.9 3.1.1L12 3Z"/></svg>
    {% when 'battery' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="7" width="16" height="10" rx="2"/><path d="M21 10v4M7 10v4M10 10v4M13 10v4"/></svg>
    {% when 'drop' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3s6 6.3 6 11a6 6 0 1 1-12 0c0-4.7 6-11 6-11Z"/></svg>
    {% when 'brush' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m14 4 6 6M4 20c2 0 4-1 5-3l7-7-4-4-7 7c-2 1-3 3-3 5 0 1.1.9 2 2 2Z"/></svg>
    {% when 'clock' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v6l4 2"/></svg>
    {% when 'gift' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12v8H4v-8M2 7h20v5H2z"/><path d="M12 7v13M12 7H8.5a2.5 2.5 0 1 1 0-5C11 2 12 7 12 7Zm0 0h3.5a2.5 2.5 0 1 0 0-5C13 2 12 7 12 7Z"/></svg>
    {% when 'menu' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
    {% when 'support' %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9.2 9.2a3.1 3.1 0 0 1 5.6 1.8c0 2.1-2.8 2.7-2.8 4.5"/><circle cx="12" cy="17.2" r=".8" fill="currentColor" stroke="none"/></svg>
    {% when 'tiktok' %}
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M15.7 2h3c.4 2 1.8 3.8 3.3 4.6v3.1a8.8 8.8 0 0 1-3.3-1.2v6.2a6.7 6.7 0 1 1-6.7-6.7c.3 0 .5 0 .8.1v3.3a3.7 3.7 0 1 0 2.9 3.6V2Z"/></svg>
    {% else %}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/></svg>
  {% endcase %}
</span>

{% stylesheet %}
  .tiktok-icon {
    width: var(--icon-size);
    height: var(--icon-size);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .tiktok-icon > svg {
    width: 100%;
    height: 100%;
  }
{% endstylesheet %}
