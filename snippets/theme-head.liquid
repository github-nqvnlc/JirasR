{% doc %}
  Renders the shared head content for theme layouts.

  Loads CSS variables, fonts, compiled Tailwind output, base landing styles,
  and SEO metadata.
{% enddoc %}

{% render 'css-variables' %}

{% comment %}
  Font preloading:
  1. Preconnect to font CDN for faster connection
  2. Preload only the critical font variant (base weight)
  3. Additional variants load on-demand via @font-face
{% endcomment %}
{% unless settings.type_primary_font.system? %}
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
{% endunless %}

{% assign tailwind_css = 'tailwind.css' | asset_url %}
<link rel="stylesheet" href="{{ tailwind_css }}" type="text/css" media="all">

{% style %}
  :root {
    color-scheme: light;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--color-background);
    color: var(--color-foreground);
    font-family: var(--font-primary--family);
    font-style: var(--font-primary--style);
    font-weight: var(--font-primary--weight);
  }

  img,
  video,
  svg {
    display: block;
    max-width: 100%;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
  }

  a {
    color: inherit;
  }

  .tiktok-shell {
    width: min(100%, 76rem);
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
  }

  .tiktok-section {
    padding-block: clamp(2.5rem, 7vw, 5rem);
  }

  .tiktok-section--compact {
    padding-block: clamp(1.25rem, 4vw, 2rem);
  }

  .tiktok-card {
    border: 1px solid var(--color-tiktok-card-border);
    border-radius: var(--style-tiktok-card-radius);
    background: var(--color-tiktok-card-background);
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
  }

  .tiktok-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: 999px;
    background: rgba(255, 92, 56, 0.12);
    color: var(--color-tiktok-accent);
    padding: 0.45rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .tiktok-eyebrow {
    margin: 0 0 0.85rem;
    color: var(--color-tiktok-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tiktok-heading {
    margin: 0;
    font-size: clamp(1.8rem, 4.5vw, 3.25rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .tiktok-subheading {
    margin: 0.9rem 0 0;
    max-width: 44rem;
    color: color-mix(in srgb, var(--color-foreground) 72%, white);
    font-size: clamp(1rem, 2.8vw, 1.15rem);
    line-height: 1.65;
  }

  .tiktok-grid {
    display: grid;
    gap: 1rem;
  }

  .tiktok-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .tiktok-product-form {
    display: grid;
    gap: 0.9rem;
  }

  .tiktok-input,
  .tiktok-select {
    width: 100%;
    border: 1px solid var(--color-tiktok-card-border);
    border-radius: 999px;
    background: #fff;
    color: var(--color-foreground);
    padding: 0.95rem 1rem;
  }

  .tiktok-qty {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tiktok-money {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.65rem;
  }

  .tiktok-money__sale {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.05em;
  }

  .tiktok-money__compare {
    color: color-mix(in srgb, var(--color-foreground) 48%, white);
    font-size: 1rem;
    text-decoration: line-through;
  }

  .tiktok-money__badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    background: var(--color-tiktok-accent);
    color: var(--color-tiktok-accent-foreground);
    padding: 0.35rem 0.7rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .tiktok-stars {
    color: #ff9f0a;
    letter-spacing: 0.18em;
    font-size: 0.9rem;
  }

  .tiktok-divider {
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--color-tiktok-card-border) 75%, transparent);
    margin: 0;
  }

  @media screen and (min-width: 990px) {
    .tiktok-desktop-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem;
      align-items: start;
    }
  }
{% endstyle %}

{% render 'meta-tags' %}
