{% liquid
  assign logo_width = section.settings.logo_width | default: 120
%}

<section class="tiktok-header-minimal{% if section.settings.sticky_header %} tiktok-header-minimal--sticky{% endif %}">
  <div class="tiktok-shell">
    <div class="tiktok-header-minimal__row">
      <a class="tiktok-header-minimal__brand" href="{{ routes.root_url }}">
        {% if section.settings.logo %}
          {{ section.settings.logo | image_url: width: logo_width | image_tag: widths: '120, 180, 240', width: logo_width, alt: shop.name }}
        {% else %}
          <span>{{ shop.name }}</span>
        {% endif %}
      </a>

      <div class="tiktok-header-minimal__actions">
        {% if section.settings.show_support_link %}
          {% if section.settings.support_url != blank %}
            <a class="tiktok-header-minimal__support" href="{{ section.settings.support_url }}">
              {% render 'icon', name: 'support', size: 16 %}
              {{ section.settings.support_text | default: 'Need help?' }}
            </a>
          {% endif %}
        {% endif %}

        {% if section.settings.show_menu_icon %}
          <button class="tiktok-header-minimal__menu" type="button" aria-label="Menu">
            {% render 'icon', name: 'menu', size: 18 %}
          </button>
        {% endif %}
      </div>
    </div>

    {% if section.settings.show_announcement %}
      {% if section.settings.announcement_text != blank %}
        <p class="tiktok-header-minimal__announcement">{{ section.settings.announcement_text }}</p>
      {% endif %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .tiktok-header-minimal {
    position: relative;
    z-index: 20;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-tiktok-card-border) 85%, transparent);
  }

  .tiktok-header-minimal--sticky {
    position: sticky;
    top: 0;
  }

  .tiktok-header-minimal__row {
    min-height: 4.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .tiktok-header-minimal__brand {
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .tiktok-header-minimal__brand img {
    width: auto;
    height: auto;
  }

  .tiktok-header-minimal__actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .tiktok-header-minimal__support,
  .tiktok-header-minimal__menu {
    border-radius: 999px;
    border: 1px solid var(--color-tiktok-card-border);
    background: #fff;
    min-height: 2.6rem;
    padding: 0.7rem 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
  }

  .tiktok-header-minimal__menu {
    cursor: pointer;
  }

  .tiktok-header-minimal__announcement {
    margin: 0 0 0.95rem;
    color: var(--color-tiktok-accent);
    font-size: 0.9rem;
    font-weight: 700;
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header Minimal",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 220,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 120
    },
    {
      "type": "checkbox",
      "id": "show_menu_icon",
      "label": "Show menu icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_link",
      "label": "Show support link",
      "default": true
    },
    {
      "type": "text",
      "id": "support_text",
      "label": "Support text",
      "default": "Need help?"
    },
    {
      "type": "url",
      "id": "support_url",
      "label": "Support URL"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Free shipping today only"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky header",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Header Minimal"
    }
  ]
}
{% endschema %}
