{% liquid
  assign bundle_product = section.settings.product | default: product
  assign bundle_form_id = 'BundleForm-' | append: section.id
  assign manual_variant_placeholder = 'manual'

  if bundle_product
    assign first_variant = bundle_product.selected_or_first_available_variant
    assign selected_variant_id = first_variant.id

    if section.settings.auto_select_first_option
      for block in section.blocks
        if block.type == 'bundle_option'
          assign selected_variant_id = block.settings.variant_id

          if selected_variant_id == blank or selected_variant_id == manual_variant_placeholder
            assign selected_variant_id = first_variant.id
          endif

          break
        endif
      endfor
    endif
  endif
%}

{% if bundle_product %}
  <section class="tiktok-section bundle-selector" id="BundleSelector-{{ section.id }}" data-product-id="{{ bundle_product.id }}">
    <div class="tiktok-shell">
      {% render 'section-heading', heading: section.settings.heading, subheading: section.settings.subheading, alignment: 'left' %}

      {% form 'product', bundle_product, id: bundle_form_id, class: 'bundle-selector__form', data-product-form: '', data-product-id: bundle_product.id %}
        <input type="hidden" name="id" value="{{ selected_variant_id }}" data-product-variant-id>
        <input type="hidden" name="quantity" value="1" data-product-quantity-input>

        <div class="bundle-selector__options">
          {% for block in section.blocks %}
            {% if block.type == 'bundle_option' %}
              {% assign option_variant_id = block.settings.variant_id %}

              {% if option_variant_id == blank or option_variant_id == manual_variant_placeholder %}
                {% assign option_variant_id = first_variant.id %}
              {% endif %}

              {% render 'bundle-option-card',
                section_id: section.id,
                block_id: block.id,
                title: block.settings.title,
                subtitle: block.settings.subtitle,
                price: block.settings.price,
                compare_price: block.settings.compare_price,
                badge: block.settings.badge,
                shipping_note: block.settings.shipping_note,
                variant_id: option_variant_id,
                checked: option_variant_id == selected_variant_id
              %}
            {% endif %}
          {% endfor %}
        </div>

        <div class="bundle-selector__footer">
          {% render 'button', label: section.settings.cta_label | default: 'Add bundle to cart', type: 'submit', style: 'primary', full_width: true %}
        </div>
      {% endform %}
    </div>
  </section>
{% endif %}

{% javascript %}
  (() => {
    const section = document.getElementById('BundleSelector-{{ section.id }}');

    if (!section) {
      return;
    }

    const productId = String(section.dataset.productId || '');
    const form = section.querySelector('[data-product-form]');

    if (!productId || !form) {
      return;
    }

    const radios = section.querySelectorAll('input[type="radio"]');
    const hiddenVariant = form.querySelector('[data-product-variant-id]');

    const markSelected = (variantId) => {
      radios.forEach((radio) => {
        const card = radio.closest('[data-bundle-option]');
        const selected = String(radio.value) === String(variantId);

        radio.checked = selected;

        if (card) {
          card.classList.toggle('is-selected', selected);
        }
      });

      if (hiddenVariant) {
        hiddenVariant.value = variantId;
      }
    };

    radios.forEach((radio) => {
      radio.addEventListener('change', () => {
        if (!radio.checked) {
          return;
        }

        const variant = window.TiktokLanding && window.TiktokLanding.findVariant ? window.TiktokLanding.findVariant(productId, radio.value) : null;
        markSelected(radio.value);

        if (window.TiktokLanding && window.TiktokLanding.syncProductState) {
          window.TiktokLanding.syncProductState(productId, {
            productId,
            variantId: radio.value,
            quantity: 1,
            variant,
            source: section.id
          });
        }
      });
    });

    window.addEventListener(`tiktok:product-sync:${productId}`, (event) => {
      const detail = event.detail || {};

      if (detail.source === section.id) {
        return;
      }

      if (detail.variantId) {
        const matchingOption = section.querySelector(`input[type="radio"][value="${detail.variantId}"]`);

        if (matchingOption) {
          markSelected(detail.variantId);
        }
      }
    });
  })();
{% endjavascript %}

{% stylesheet %}
  .bundle-selector__options {
    display: grid;
    gap: 0.9rem;
  }

  .bundle-selector__footer {
    margin-top: 1rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bundle Selector",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your deal"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Use a few large tap targets so the bundle decision feels fast and obvious."
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Add bundle to cart"
    },
    {
      "type": "checkbox",
      "id": "auto_select_first_option",
      "label": "Auto-select first option",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "bundle_option",
      "name": "Bundle option",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "1 Pack"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Starter order"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$29.99"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Compare price",
          "default": "$49.99"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "Best value"
        },
        {
          "type": "text",
          "id": "shipping_note",
          "label": "Shipping note",
          "default": "Free shipping included"
        },
        {
          "type": "text",
          "id": "variant_id",
          "label": "Variant ID",
          "default": "manual"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Bundle Selector",
      "blocks": [
        {
          "type": "bundle_option"
        },
        {
          "type": "bundle_option"
        },
        {
          "type": "bundle_option"
        }
      ]
    }
  ]
}
{% endschema %}
