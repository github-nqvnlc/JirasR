<section class="tiktok-section faq-accordion">
  <div class="tiktok-shell">
    {% render 'section-heading', heading: section.settings.heading, alignment: 'left' %}

    <div>
      {% for block in section.blocks %}
        {% render 'accordion-item', title: block.settings.question, content: block.settings.answer, open: section.settings.open_first_item and forloop.first %}
      {% endfor %}
    </div>

    {% if section.settings.show_contact_cta %}
      {% if section.settings.contact_url != blank %}
        <div class="faq-accordion__contact">
          {% render 'button', href: section.settings.contact_url, label: section.settings.contact_label | default: 'Contact support', style: 'secondary' %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .faq-accordion__contact {
    margin-top: 1.1rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ Accordion",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "checkbox",
      "id": "show_contact_cta",
      "label": "Show contact CTA",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact label",
      "default": "Contact support"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact URL"
    },
    {
      "type": "checkbox",
      "id": "open_first_item",
      "label": "Open first item",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Use this area to answer the final objections that block a buyer from converting.</p>"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        {
          "type": "faq"
        },
        {
          "type": "faq"
        },
        {
          "type": "faq"
        }
      ]
    }
  ]
}
{% endschema %}
