<section class="tiktok-section tiktok-section--compact urgency-timer">
  <div class="tiktok-shell">
    {% render 'countdown-timer',
      section_id: section.id,
      heading: section.settings.heading,
      end_datetime: section.settings.end_datetime,
      expiry_behavior: section.settings.expiry_behavior,
      expiry_message: section.settings.expiry_message,
      shipping_note: section.settings.shipping_note,
      show_timer: section.settings.show_timer
    %}
  </div>
</section>

{% schema %}
{
  "name": "Urgency Timer",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited-time offer ends in"
    },
    {
      "type": "text",
      "id": "end_datetime",
      "label": "End date and time",
      "default": "2026-12-31T23:59:59"
    },
    {
      "type": "select",
      "id": "expiry_behavior",
      "label": "Expiry behavior",
      "options": [
        {
          "value": "hide",
          "label": "Hide"
        },
        {
          "value": "show_message",
          "label": "Show message"
        },
        {
          "value": "restart_daily",
          "label": "Restart daily"
        }
      ],
      "default": "show_message"
    },
    {
      "type": "text",
      "id": "expiry_message",
      "label": "Expiry message",
      "default": "This offer has just ended."
    },
    {
      "type": "text",
      "id": "shipping_note",
      "label": "Shipping note",
      "default": "Free shipping when you order today"
    },
    {
      "type": "checkbox",
      "id": "show_timer",
      "label": "Show timer",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Urgency Timer"
    }
  ]
}
{% endschema %}
