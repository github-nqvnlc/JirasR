<section class="tiktok-section ugc-video-carousel">
  <div class="tiktok-shell">
    {% render 'section-heading', heading: section.settings.heading, subheading: section.settings.subheading, alignment: 'left' %}

    <div class="ugc-video-carousel__track" data-ugc-carousel>
      {% for block in section.blocks %}
        <div class="ugc-video-carousel__slide">
          {% render 'video-card',
            video: block.settings.video,
            poster: block.settings.poster,
            caption: block.settings.caption,
            author: block.settings.author,
            show_badge: section.settings.show_badge,
            badge_text: section.settings.badge_text,
            show_captions: section.settings.show_captions
          %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .ugc-video-carousel__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(72%, 1fr);
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    scroll-snap-type: x mandatory;
  }

  .ugc-video-carousel__slide {
    scroll-snap-align: start;
  }

  @media screen and (min-width: 990px) {
    .ugc-video-carousel__track {
      grid-auto-flow: initial;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      overflow: visible;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const videos = document.querySelectorAll('.tiktok-ugc-video');

    videos.forEach((video) => {
      video.addEventListener('play', () => {
        videos.forEach((otherVideo) => {
          if (otherVideo !== video) {
            otherVideo.pause();
            otherVideo.muted = true;
          }
        });
      });

      video.addEventListener('click', () => {
        video.muted = !video.muted;
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "UGC Video Carousel",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real customer videos"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Use vertical social-style videos to keep the page feeling native to paid traffic."
    },
    {
      "type": "checkbox",
      "id": "show_captions",
      "label": "Show captions",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Seen on TikTok"
    }
  ],
  "blocks": [
    {
      "type": "ugc_video",
      "name": "UGC video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Poster image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Works exactly as shown in the ad."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "@verifiedbuyer"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "UGC Video Carousel",
      "blocks": [
        {
          "type": "ugc_video"
        },
        {
          "type": "ugc_video"
        },
        {
          "type": "ugc_video"
        }
      ]
    }
  ]
}
{% endschema %}
