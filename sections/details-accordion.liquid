<section class="tiktok-section details-accordion">
  <div class="tiktok-shell">
    {% render 'section-heading', heading: section.settings.heading, alignment: 'left' %}

    <div>
      {% for block in section.blocks %}
        {% render 'accordion-item', title: block.settings.title, content: block.settings.content, open: section.settings.open_first_item and forloop.first %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Details Accordion",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product details"
    },
    {
      "type": "checkbox",
      "id": "open_first_item",
      "label": "Open first item",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Materials"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Use this space for specs, sizing, shipping, warranty, or care details.</p>"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Details Accordion",
      "blocks": [
        {
          "type": "item"
        },
        {
          "type": "item"
        },
        {
          "type": "item"
        }
      ]
    }
  ]
}
{% endschema %}
