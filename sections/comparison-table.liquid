<section class="tiktok-section comparison-table">
  <div class="tiktok-shell">
    {% render 'section-heading', heading: section.settings.heading, subheading: section.settings.subheading, alignment: 'center' %}

    <div class="comparison-table__wrap tiktok-card">
      <div class="comparison-table__header">
        <div></div>
        <div class="comparison-table__label comparison-table__label--left">{{ section.settings.left_label }}</div>
        {% if section.settings.show_right_column %}
          <div class="comparison-table__label">{{ section.settings.right_label }}</div>
        {% endif %}
      </div>

      {% for block in section.blocks %}
        {% render 'comparison-row',
          feature: block.settings.feature,
          left_value: block.settings.left_value,
          right_value: block.settings.right_value,
          show_right: section.settings.show_right_column
        %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .comparison-table__wrap {
    overflow: hidden;
  }

  .comparison-table__header {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) repeat(2, minmax(0, 0.75fr));
    gap: 0.75rem;
    padding: 1rem;
    background: color-mix(in srgb, var(--color-tiktok-surface) 78%, white);
  }

  .comparison-table__label {
    text-align: center;
    font-weight: 700;
  }

  .comparison-table__label--left {
    color: var(--color-tiktok-accent);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Comparison Table",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why choose us?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Keep the table short so it reinforces the offer instead of feeling like a spec sheet."
    },
    {
      "type": "text",
      "id": "left_label",
      "label": "Left label",
      "default": "Ours"
    },
    {
      "type": "text",
      "id": "right_label",
      "label": "Right label",
      "default": "Others"
    },
    {
      "type": "checkbox",
      "id": "show_right_column",
      "label": "Show right column",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Fast cleaning"
        },
        {
          "type": "text",
          "id": "left_value",
          "label": "Left value",
          "default": "check"
        },
        {
          "type": "text",
          "id": "right_value",
          "label": "Right value",
          "default": "cross"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        }
      ]
    }
  ]
}
{% endschema %}
