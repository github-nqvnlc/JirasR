{% liquid
  assign landing_product = section.settings.product | default: product
  assign product_form_id = 'ProductHeroForm-' | append: section.id

  if landing_product
    assign active_variant = landing_product.selected_or_first_available_variant
  endif
%}

{% if landing_product %}
  <section
    id="Hero-{{ section.id }}"
    class="tiktok-section product-hero-video"
    data-product-id="{{ landing_product.id }}"
    data-product-hero="{{ landing_product.id }}"
    style="padding-top: {{ section.settings.section_spacing_top }}px; padding-bottom: {{ section.settings.section_spacing_bottom }}px;"
  >
    <div class="tiktok-shell">
      <div class="tiktok-desktop-grid product-hero-video__grid">
        <div class="product-hero-video__media">
          {% render 'media-gallery',
            product: landing_product,
            section_id: section.id,
            hero_media_mode: section.settings.hero_media_mode,
            main_video: section.settings.main_video,
            main_image: section.settings.main_image,
            show_thumbnails: section.settings.show_thumbnails,
            autoplay_video: section.settings.autoplay_video,
            loop_video: section.settings.loop_video,
            mute_video: section.settings.mute_video,
            badge_text: section.settings.badge_text,
            media_ratio_mobile: section.settings.media_ratio_mobile,
            media_ratio_desktop: section.settings.media_ratio_desktop
          %}
        </div>

        <div class="product-hero-video__content">
          {% if section.settings.headline != blank %}
            <h1 class="product-hero-video__headline">{{ section.settings.headline }}</h1>
          {% else %}
            <h1 class="product-hero-video__headline">{{ landing_product.title }}</h1>
          {% endif %}

          {% if section.settings.subheadline != blank %}
            <div class="product-hero-video__subheadline">{{ section.settings.subheadline }}</div>
          {% endif %}

          {% if section.settings.show_rating_summary %}
            <div class="product-hero-video__rating">
              <span class="tiktok-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
              <span>{{ section.settings.rating_text }}</span>
            </div>
          {% endif %}

          {% if section.settings.show_price %}
            {% render 'price', product: landing_product, variant: active_variant, show_compare: section.settings.show_compare_price, show_badge: true, class: 'product-hero-video__price' %}
          {% endif %}

          {% form 'product', landing_product, id: product_form_id, class: 'tiktok-product-form product-hero-video__form', data-product-form: '', data-product-id: landing_product.id %}
            <input type="hidden" name="quantity" value="1" data-product-quantity-input>

            {% if landing_product.variants.size > 1 %}
              <label class="tiktok-sr-only" for="HeroVariant-{{ section.id }}">Variant</label>
              <select id="HeroVariant-{{ section.id }}" class="tiktok-select" name="id" data-product-variant-select>
                {% for variant in landing_product.variants %}
                  <option value="{{ variant.id }}"{% if variant.id == active_variant.id %} selected{% endif %}>
                    {{ variant.title }} - {{ variant.price | money }}
                  </option>
                {% endfor %}
              </select>
            {% else %}
              <input type="hidden" name="id" value="{{ active_variant.id }}" data-product-variant-id>
            {% endif %}

            <div class="tiktok-qty">
              <label for="HeroQuantity-{{ section.id }}">Quantity</label>
              <input id="HeroQuantity-{{ section.id }}" class="tiktok-input product-hero-video__quantity" type="number" min="1" value="1" data-product-quantity-visible>
            </div>

            <div class="product-hero-video__buttons">
              {% render 'button', label: section.settings.primary_cta_label | default: 'Buy now', type: 'submit', style: 'primary', full_width: true, class: 'product-hero-video__submit' %}

              {% if section.settings.show_secondary_cta %}
                {% render 'button', label: section.settings.secondary_cta_label | default: 'Add to cart', type: 'submit', style: 'secondary', full_width: true, class: 'product-hero-video__submit' %}
              {% endif %}
            </div>

            {% if section.settings.show_dynamic_checkout %}
              <div class="product-hero-video__dynamic-checkout">
                {{ form | payment_button }}
              </div>
            {% endif %}
          {% endform %}

          {% if section.settings.show_trust_bullets %}
            <div class="product-hero-video__trust product-hero-video__trust--{{ section.settings.trust_style }}">
              {% for block in section.blocks %}
                {% if block.type == 'trust_bullet' %}
                  {% render 'trust-bullet', icon: block.settings.icon, text: block.settings.text %}
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>

    <script type="application/json" data-product-variants>{{ landing_product.variants | json }}</script>
  </section>
{% endif %}

{% javascript %}
  (() => {
    const section = document.getElementById('Hero-{{ section.id }}');

    if (!section) {
      return;
    }

    const productId = String(section.dataset.productId || '');
    const form = section.querySelector('[data-product-form]');
    const variantsNode = section.querySelector('[data-product-variants]');

    if (!productId || !form || !variantsNode) {
      return;
    }

    const variants = JSON.parse(variantsNode.textContent || '[]');
    const variantSelect = form.querySelector('[data-product-variant-select]');
    const variantInput = form.querySelector('[data-product-variant-id]');
    const quantityVisible = form.querySelector('[data-product-quantity-visible]');
    const quantityInput = form.querySelector('[data-product-quantity-input]');
    const currencyCode = '{{ cart.currency.iso_code | default: shop.currency }}';

    window.TiktokLanding = window.TiktokLanding || {};
    window.TiktokLanding.products = window.TiktokLanding.products || {};
    window.TiktokLanding.products[productId] = variants;

    if (!window.TiktokLanding.money) {
      window.TiktokLanding.money = (cents, currency) => {
        const formatter = new Intl.NumberFormat(document.documentElement.lang || 'en-US', {
          style: 'currency',
          currency: currency || currencyCode
        });

        return formatter.format((cents || 0) / 100);
      };
    }

    if (!window.TiktokLanding.findVariant) {
      window.TiktokLanding.findVariant = (id, variantId) => {
        const productVariants = (window.TiktokLanding.products || {})[String(id)] || [];
        return productVariants.find((variant) => String(variant.id) === String(variantId));
      };
    }

    if (!window.TiktokLanding.updatePriceBlocks) {
      window.TiktokLanding.updatePriceBlocks = (variant) => {
        if (!variant) {
          return;
        }

        document.querySelectorAll('[data-product-price-root]').forEach((root) => {
          const priceNode = root.querySelector('[data-product-price]');
          const compareNode = root.querySelector('[data-product-compare]');
          const badgeNode = root.querySelector('[data-product-badge]');

          if (priceNode) {
            priceNode.textContent = window.TiktokLanding.money(variant.price, currencyCode);
          }

          if (compareNode) {
            if (variant.compare_at_price && variant.compare_at_price > variant.price) {
              compareNode.hidden = false;
              compareNode.textContent = window.TiktokLanding.money(variant.compare_at_price, currencyCode);
            } else {
              compareNode.hidden = true;
            }
          }

          if (badgeNode) {
            if (variant.compare_at_price && variant.compare_at_price > variant.price) {
              const percentage = Math.round(((variant.compare_at_price - variant.price) / variant.compare_at_price) * 100);
              badgeNode.hidden = false;
              badgeNode.textContent = `Save ${percentage}%`;
            } else {
              badgeNode.hidden = true;
            }
          }
        });
      };
    }

    if (!window.TiktokLanding.syncProductState) {
      window.TiktokLanding.syncProductState = (id, detail) => {
        window.dispatchEvent(new CustomEvent(`tiktok:product-sync:${id}`, { detail }));
      };
    }

    const syncControls = (detail) => {
      if (detail.variantId) {
        if (variantSelect) {
          variantSelect.value = String(detail.variantId);
        }

        if (variantInput) {
          variantInput.value = String(detail.variantId);
        }
      }

      if (detail.quantity) {
        if (quantityVisible) {
          quantityVisible.value = detail.quantity;
        }

        if (quantityInput) {
          quantityInput.value = detail.quantity;
        }
      }

      if (detail.variant) {
        window.TiktokLanding.updatePriceBlocks(detail.variant);

        const submitButtons = form.querySelectorAll('button[type="submit"]');
        submitButtons.forEach((button) => {
          button.disabled = detail.variant.available === false;
        });
      }
    };

    const emitState = (source) => {
      const variantId = variantSelect ? variantSelect.value : variantInput ? variantInput.value : '';
      const quantity = quantityVisible ? Math.max(1, parseInt(quantityVisible.value || '1', 10)) : 1;
      const variant = window.TiktokLanding.findVariant(productId, variantId);

      if (quantityVisible) {
        quantityVisible.value = quantity;
      }

      if (quantityInput) {
        quantityInput.value = quantity;
      }

      syncControls({ variantId, quantity, variant });
      window.TiktokLanding.syncProductState(productId, { productId, variantId, quantity, variant, source });
    };

    if (variantSelect) {
      variantSelect.addEventListener('change', () => emitState(section.id));
    }

    if (quantityVisible) {
      ['change', 'input'].forEach((eventName) => {
        quantityVisible.addEventListener(eventName, () => emitState(section.id));
      });
    }

    window.addEventListener(`tiktok:product-sync:${productId}`, (event) => {
      const detail = event.detail || {};

      if (detail.source === section.id) {
        return;
      }

      syncControls(detail);
    });

    emitState(section.id);
  })();
{% endjavascript %}

{% stylesheet %}
  .product-hero-video {
    background: linear-gradient(180deg, #fff7f4 0%, rgba(255, 255, 255, 0.94) 100%);
  }

  .product-hero-video__grid {
    gap: 1.5rem;
  }

  .product-hero-video__content {
    display: grid;
    gap: 1rem;
    align-self: center;
  }

  .product-hero-video__headline {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.6rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .product-hero-video__subheadline {
    color: color-mix(in srgb, var(--color-foreground) 76%, white);
    line-height: 1.7;
  }

  .product-hero-video__rating {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
  }

  .product-hero-video__buttons {
    display: grid;
    gap: 0.75rem;
  }

  .product-hero-video__trust {
    display: grid;
    gap: 0.7rem;
  }

  .product-hero-video__trust--inline {
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
  }

  .product-hero-video__quantity {
    max-width: 7rem;
    text-align: center;
  }
{% endstylesheet %}

